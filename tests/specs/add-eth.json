[
  {
    "name": "Add ETH to watchlist",
    "steps": [
      {
        "send": { "callback": "add:ETH" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "✅ Added ETH to your watchlist." }
          }
        ]
      }
    ]
  },
  {
    "name": "Add ETH again shows already-in-watchlist",
    "steps": [
      { "send": { "callback": "add:ETH" }, "expect": [{ "method": "sendMessage" }] },
      { "send": { "callback": "add:ETH" }, "expect": [{ "method": "sendMessage", "payload": { "text": "ETH is already in your watchlist." } }] }
    ]
  }
]
