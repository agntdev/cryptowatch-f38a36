[
  {
    "name": "Add TON to watchlist",
    "steps": [
      {
        "send": { "callback": "add:TON" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "✅ Added TON to your watchlist." }
          }
        ]
      }
    ]
  },
  {
    "name": "Add TON again shows already-in-watchlist",
    "steps": [
      { "send": { "callback": "add:TON" }, "expect": [{ "method": "sendMessage" }] },
      { "send": { "callback": "add:TON" }, "expect": [{ "method": "sendMessage", "payload": { "text": "TON is already in your watchlist." } }] }
    ]
  }
]
