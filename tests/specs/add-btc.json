[
  {
    "name": "Add BTC to watchlist",
    "steps": [
      {
        "send": { "callback": "add:BTC" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "✅ Added BTC to your watchlist." }
          }
        ]
      }
    ]
  },
  {
    "name": "Add BTC again shows already-in-watchlist",
    "steps": [
      { "send": { "callback": "add:BTC" }, "expect": [{ "method": "sendMessage" }] },
      { "send": { "callback": "add:BTC" }, "expect": [{ "method": "sendMessage", "payload": { "text": "BTC is already in your watchlist." } }] }
    ]
  }
]
